# ── Telegram ──────────────────────────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_TOKEN=1234567890:AAFakeTokenHere

# Ваш Telegram user ID (узнать: @userinfobot)
OWNER_TELEGRAM_ID=123456789

# ── Шифрование БД ─────────────────────────────────────────────────────────
# Сгенерировать ключ:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Если не задан — пароли хранятся в открытом виде (не рекомендуется)
FERNET_KEY=

# ── Пути ──────────────────────────────────────────────────────────────────
DB_PATH=apple_bot.db
LOG_PATH=apple_bot.log

# ── Браузер ───────────────────────────────────────────────────────────────
# false = показывает браузер (рекомендуется при первом входе и отладке)
# true  = скрытый режим (для сервера без GUI)
HEADLESS=false

# ── Мониторинг ────────────────────────────────────────────────────────────
# Интервал проверки в секундах (300 = 5 минут)
MONITOR_INTERVAL=300
